# Do not copy manually. Generate deploy/enterprise/.env and secrets with:
# python scripts/enterprise_init.py --host thistinti.example.com \
#   --accept-operator-responsibility --accept-no-support
THISTINTI_PUBLIC_HOST=thistinti.example.com
THISTINTI_DEPLOYMENT_ID=selfhost-example-change-me
THISTINTI_CORS_ORIGINS=https://thistinti.example.com
THISTINTI_OPERATOR_ACCEPTS_SELF_HOSTING_RESPONSIBILITY=true
THISTINTI_OPERATOR_ACCEPTS_NO_SUPPORT=true
THISTINTI_WORKER_REPLICAS=2
THISTINTI_COMPLETED_JOB_RETENTION_DAYS=30
THISTINTI_QUARANTINE_RETENTION_HOURS=24
