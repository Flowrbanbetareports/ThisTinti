# Public DNS name pointing to the staging host.
THISTINTI_PUBLIC_HOST=staging.example.com

# Generate independent URL-safe values. Never commit the populated file.
THISTINTI_POSTGRES_ADMIN_PASSWORD=replace-with-random-admin-password
THISTINTI_DB_OWNER_PASSWORD=replace-with-random-owner-password
THISTINTI_DB_APP_PASSWORD=replace-with-random-runtime-password
THISTINTI_SECRET_KEY=replace-with-at-least-48-random-characters

THISTINTI_ENV=staging
THISTINTI_ALLOW_REGISTRATION=true
THISTINTI_SECURE_COOKIES=true
THISTINTI_CORS_ORIGINS=https://staging.example.com
THISTINTI_DATABASE_RATE_LIMITING=true
THISTINTI_ASYNC_INGESTION_ENABLED=true
THISTINTI_ALLOW_SYNCHRONOUS_INGESTION=false
THISTINTI_REQUIRE_MALWARE_SCANNER=false
THISTINTI_OCR_ENABLED=true
THISTINTI_OCR_LANGUAGES=ita+eng
