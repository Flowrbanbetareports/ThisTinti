# Use URL-safe random values (letters, digits, dash and underscore) because these are embedded in DB URLs.
THISTINTI_POSTGRES_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
THISTINTI_DB_OWNER_PASSWORD=replace-with-a-different-long-owner-password
THISTINTI_DB_APP_PASSWORD=replace-with-a-different-long-runtime-password
THISTINTI_SECRET_KEY=replace-with-at-least-48-random-characters

THISTINTI_ENV=development
THISTINTI_ALLOW_REGISTRATION=true
THISTINTI_SECURE_COOKIES=false
THISTINTI_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

THISTINTI_DATABASE_RATE_LIMITING=true
THISTINTI_ASYNC_INGESTION_ENABLED=true
THISTINTI_ALLOW_SYNCHRONOUS_INGESTION=false
THISTINTI_WORKER_MAX_ATTEMPTS=3
THISTINTI_WORKER_LEASE_SECONDS=300
THISTINTI_WORKER_HEARTBEAT_STALE_SECONDS=30
THISTINTI_COMPLETED_JOB_RETENTION_DAYS=30
THISTINTI_QUARANTINE_RETENTION_HOURS=24

# In produzione il comando deve esistere nei container app/worker e raggiungere uno scanner reale.
THISTINTI_REQUIRE_MALWARE_SCANNER=false
THISTINTI_MALWARE_SCANNER_COMMAND=clamdscan
THISTINTI_MALWARE_SCAN_TIMEOUT_SECONDS=60

THISTINTI_OCR_ENABLED=true
THISTINTI_OCR_LANGUAGES=ita+eng
THISTINTI_OCR_MAX_PAGES=20
THISTINTI_OCR_DPI=200
THISTINTI_OCR_TIMEOUT_SECONDS=45
THISTINTI_OCR_MAX_CHARS=2000000
